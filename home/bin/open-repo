#!/usr/bin/env zsh

if [[ -z $1 ]]; then
    echo "Error: No directory provided"
    exit 1
fi

local dir=$1
local name=$(basename $dir)

~/dotfiles/home/bin/kitty-wrapper focus-window --match title:$name

if [[ $? -eq 1 ]]; then
  echo "Unable to focus tab, launching new tab"
  ~/dotfiles/home/bin/kitty-wrapper launch --type=os-window --cwd=$dir --title=$name
else
  echo "Focused tab"
fi
