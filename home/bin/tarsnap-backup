#!/bin/sh

# Set up archive name
computer=$(uname -n)
now=$(date +%Y-%m-%d_%H-%M-%S)
name=${computer}-${now}

directories=(
  "$HOME/dotfiles"
  "$HOME/gdrive/Jardul"
  "$HOME/gdrive/Personal"

)

for dir in "${directories[@]}"; do
    if [ -d "${dir}" ]; then
        echo "Backing up: ${dir}. Time: $(date)"
        /usr/local/bin/tarsnap -c \
            -f "${name}-$(basename "$dir")" \
            -C "$(dirname "$dir")" \
            "$(basename "$dir")"

        if [ $? -eq 0 ]; then
            echo "Backup successful: ${dir}."
        else
            echo "Backup failed: ${dir}."
        fi
        echo
    else
        echo "Directory not found: ${dir}"
    fi
done
