[advice]
	detachedHead = false

[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
  ui = auto

[column]
	io = "auto row dense"

[delta]
    dark = true
    syntax-theme = gruvbox-dark

[core]
  commitGraph = true
  pager = delta

[diff]
	algorithm = "patience"

[fetch]
	prune = true

[gc]
	writeCommitGraph = true

[github]
	user = "shardulbee"

[init]
	defaultBranch = "main"

[merge]
	conflictstyle = "diff3"
	tool = "delta"

[protocol]
	version = 2

[pull]
	default = "current"
	rebase = true

[push]
	default = "current"
	autoSetupRemote = true

[rebase]
	autosquash = true

[submodule]
	recurse = true

[user]
	email = "shardul@distributional.com"
	name = "Shardul Baral"
