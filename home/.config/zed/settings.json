{
  "assistant": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-3-5-sonnet-latest"
    },
    "version": "2"
  },
  "features": {
    "inline_completion_provider": "supermaven"
  },
  "scrollbar": {
    "cursors": false,
    "diagnostics": false,
    "git_diff": false,
    "selected_symbol": false
  },
  "theme": "Gruvbox Dark Hard",
  "buffer_line_height": {
    "custom": 1.25
  },
  "vim_mode": true,
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "current_line_highlight": "gutter",
  "format_on_save": "on",
  "lsp": {
    "nil": {
      "settings": {
        "formatting": {
          "command": ["nixfmt"]
        }
      }
    }
  }
}
