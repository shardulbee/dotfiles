#!/usr/bin/env bash
set -euo pipefail

DOT="$(cd "$(dirname "$0")" && pwd -P)"

if [ "$#" -gt 0 ]; then
  echo "usage: ./setup   (no flags. want to check? run it again.)" >&2
  exit 2
fi

link() {
  src="$1"
  dst="$2"
  case "$src" in
    /*) ;;
    *) src="$DOT/$src" ;;
  esac

  if [ ! -e "$src" ]; then
    echo "error: missing source: $src" >&2
    exit 1
  fi
  if [ -e "$dst" ] && [ ! -L "$dst" ]; then
    echo "error: real file in the way: $dst (move it, rerun)" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$dst")"
  ln -snf "$src" "$dst"
}

link config/mise/config.toml "$HOME/.config/mise/config.toml"
link config/fish/config.fish "$HOME/.config/fish/config.fish"
link config/git/config "$HOME/.config/git/config"
link config/git/ignore "$HOME/.config/git/ignore"
link config/jj/config.toml "$HOME/.config/jj/config.toml"
link config/jjui/config.lua "$HOME/.config/jjui/config.lua"
link config/jjui/themes "$HOME/.config/jjui/themes"
link config/nvim/init.lua "$HOME/.config/nvim/init.lua"
link config/nvim/colors/alabaster.lua "$HOME/.config/nvim/colors/alabaster.lua"
link bin/sharview "$HOME/bin/sharview"
link config/ghostty/config "$HOME/.config/ghostty/config"
link config/ghostty/themes/alabaster-light "$HOME/.config/ghostty/themes/Alabaster Light"
link config/ghostty/themes/alabaster-dark "$HOME/.config/ghostty/themes/Alabaster Dark"
link config/zed/keymap.json "$HOME/.config/zed/keymap.json"
link config/zed/settings.json "$HOME/.config/zed/settings.json"
link config/zed/tasks.json "$HOME/.config/zed/tasks.json"

if [ "$(uname)" = "Darwin" ]; then
  brew bundle install --file "$DOT/Brewfile" --no-upgrade --force-cleanup
fi

if ! command -v mise >/dev/null; then
  curl https://mise.run | sh
  export PATH="$HOME/.local/bin:$PATH"
fi

mise trust "$HOME/.config/mise/config.toml" >/dev/null
mise install --yes
echo "Done."
