#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"
DOT="$PWD"

export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

command -v nix >/dev/null || { echo "error: install Nix first" >&2; exit 1; }

# install or upgrade dev tools
# Check if dotfiles flake is already in the profile; if so upgrade, else add.
if nix profile list | grep -F "$DOT" > /dev/null; then
    nix profile upgrade dev
else
    nix profile add "$DOT#dev"
fi

# set fish as login shell
fish="$(command -v fish)"
if [ -w /etc/shells ]; then
    grep -qxF "$fish" /etc/shells || printf '%s\n' "$fish" | sudo tee -a /etc/shells >/dev/null
fi

[[ "$SHELL" == *fish* ]] || chsh -s "$fish" 2>/dev/null || sudo chsh -s "$fish" "$USER"

link() {
  ln -snf "$1" "$2"
}

# remove broken symlinks in ~ (max depth 4)
if command -v fd >/dev/null 2>&1; then
    fd -H -t l -d 4 . "$HOME" -x sh -c '[ -e "$1" ] || rm -f "$1"' _ {} 2>/dev/null
else 
    echo "Could not find `fd` program - not cleaning up broken symlinks"
fi

mkdir -p "$HOME/.config/"{fish,git,jj,jjui,nvim/lua,nvim/colors,ghostty/themes,zed} "$HOME/.pi/agent/"{extensions,skills} "$HOME/bin" "$HOME/.npm-global/bin"

link "$DOT/config/fish/config.fish" "$HOME/.config/fish/config.fish"
link "$DOT/config/git/config" "$HOME/.config/git/config"
link "$DOT/config/git/ignore" "$HOME/.config/git/ignore"
link "$DOT/config/jj/config.toml" "$HOME/.config/jj/config.toml"
link "$DOT/config/jjui/config.lua" "$HOME/.config/jjui/config.lua"
link "$DOT/config/jjui/themes" "$HOME/.config/jjui/themes"
link "$DOT/config/nvim/init.lua" "$HOME/.config/nvim/init.lua"
link "$DOT/config/nvim/colors/alabaster_bg.lua" "$HOME/.config/nvim/colors/alabaster_bg.lua"
link "$DOT/bin/sharview" "$HOME/bin/sharview"
link "$DOT/config/pi/extensions/theme.ts" "$HOME/.pi/agent/extensions/theme.ts"
link "$DOT/config/pi/extensions/tps.ts" "$HOME/.pi/agent/extensions/tps.ts"
link "$DOT/config/pi/extensions/fast.ts" "$HOME/.pi/agent/extensions/fast.ts"
link "$DOT/config/pi/AGENTS.md" "$HOME/.pi/agent/AGENTS.md"
link "$DOT/config/pi/skills/jj" "$HOME/.pi/agent/skills/jj"

# macOS config
if [ "$(uname)" = "Darwin" ]; then
  link "$DOT/config/ghostty/config" "$HOME/.config/ghostty/config"
  link "$DOT/config/ghostty/themes/alabaster-sublime" "$HOME/.config/ghostty/themes/Alabaster Sublime"
  link "$DOT/config/ghostty/themes/alabaster-sublime-dark" "$HOME/.config/ghostty/themes/Alabaster Sublime Dark"
  link "$DOT/config/zed/keymap.json" "$HOME/.config/zed/keymap.json"
  link "$DOT/config/zed/settings.json" "$HOME/.config/zed/settings.json"
  link "$DOT/config/zed/tasks.json" "$HOME/.config/zed/tasks.json"
fi

printf 'prefix=%s/.npm-global\n' "$HOME" > "$HOME/.npmrc"

echo "========================================DONE================================="
