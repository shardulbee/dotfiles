#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"
DOT="$PWD"

export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

link() {
  ln -snf "$1" "$2"
}

mkdir -p "$HOME/.config/"{fish,git,jj,jjui,nvim/lua,nvim/colors,ghostty/themes,zed} "$HOME/.pi/agent/extensions" "$HOME/.agents/skills" "$HOME/.codex" "$HOME/bin" "$HOME/.npm-global/bin"

if ! command -v mise >/dev/null; then
  command -v curl >/dev/null || { echo "error: install mise or curl first" >&2; exit 1; }
  curl https://mise.run | sh
  export PATH="$HOME/.local/bin:$PATH"
fi

# macOS config
if [ "$(uname)" = "Darwin" ]; then
  command -v brew >/dev/null || { echo "error: install Homebrew first" >&2; exit 1; }
fi

mkdir -p "$HOME/.config/mise"
link "$DOT/config/mise/config.toml" "$HOME/.config/mise/config.toml"

mise trust "$HOME/.config/mise/config.toml" >/dev/null
mise bootstrap --yes

echo "Done."