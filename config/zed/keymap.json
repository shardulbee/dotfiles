[
  {
    "context": "Workspace > ThreadsSidebar",
    "bindings": {
      "cmd-backspace": "agent::ArchiveSelectedThread",
      "cmd-ctrl-enter": "multi_workspace::FocusWorkspaceSidebar",
    },
  },
  {
    "context": "!(Workspace > ThreadsSidebar)",
    "bindings": {
      "cmd-ctrl-enter": [
        "action::Sequence",
        [
          "multi_workspace::FocusWorkspaceSidebar",
          ["workspace::SendKeystrokes", "down down"],
        ],
      ],
    },
  },
  {
    "context": "",
    "bindings": {
      "cmd-,": "zed::OpenSettingsFile",
      "cmd-shift-,": "zed::OpenKeymapFile",
      "cmd-shift-space": "workspace::NewCenterTerminal",
      "cmd-ctrl-[": "multi_workspace::PreviousThread",
      "cmd-ctrl-]": "multi_workspace::NextThread",
    },
  },
  {
    "context": "Workspace > Dock > ProjectPanel",
    "bindings": {
      "ctrl-enter": "workspace::OpenInTerminal",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-j": ["task::Spawn", { "task_name": "Run jjui" }],
      "cmd-shift-d": "git::BranchDiff",
      ", y": "editor::CopyRelativePath",
      ", g b": "editor::OpenPermalinkToLine",
      ", f e": [
        "pane::DeploySearch",
        { "excluded_files": "*.har, *.json, *.spec.ts, inlinedbaml.ts" },
      ],
      ", f f": [
        "pane::DeploySearch",
        { "excluded_files": "", "included_files": "" },
      ],
    },
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      ", c": [
        "action::Sequence",
        [
          "vim::InsertLineAbove",
          ["workspace::SendKeystrokes", "cmd-/ SHARVIEW: space"],
        ],
      ],
    },
  },
  {
    "context": "Editor && vim_mode == visual && !menu",
    "bindings": {
      "v": "editor::SelectLargerSyntaxNode",
      "V": "editor::SelectSmallerSyntaxNode",
    },
  },
  {
    "context": "Terminal && !Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "bindings": {
      "cmd-`": "workspace::ToggleZoom",
    },
  },
  {
    "unbind": {
      "shift-escape": "workspace::ToggleZoom",
    },
  },
]
