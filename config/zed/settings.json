{
  "disable_ai": true,
  "theme": {
    "light": "Alabaster BG",
    "dark": "Alabaster Dark",
  },
  "outline_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": true,
    "hide_root": true,
  },
  "collaboration_panel": {
    "button": false,
  },
  "close_panel_on_toggle": true,
  "git_panel": {
    "button": false,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "diff_view_style": "split",
  "buffer_font_size": 18,
  "buffer_font_weight": 300,
  "terminal": {
    "font_weight": 300,
  },
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "vim_mode": true,
  "use_system_window_tabs": true,
  "load_direnv": "direct",
  "languages": {
    "Nix": {
      "language_servers": ["nil", "!nixds"],
      "formatter": {
        "external": {
          "command": "nixfmt",
          "arguments": ["--"],
        },
      },
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
}
